# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# 관리자 유저 ID (쉼표 구분, /stats 등 관리자 명령어 허용)
ADMIN_USER_IDS=

# 자동발송 대상 채널/공지방 ID
# 채널은 음수값: 예) -1001234567890
# 뉴스, 김프, 경제캘린더 자동발송에 사용
ANNOUNCE_CHAT_ID=

# 한국투자증권 OpenAPI (https://apiportal.koreainvestment.com)
# 현재가/등락률/거래량 실시간 조회용
# 미설정 시 pykrx 마지막 종가로 자동 fallback
KIS_APP_KEY=
KIS_APP_SECRET=
